<resources>
    <!-- Neumorphism Base Colors (Light Theme) -->
    <color name="neumorphic_background">#E0E0E0</color> <!-- A light, soft gray base -->
    <color name="neumorphic_light_shadow">#FFFFFF</color> <!-- For highlight/top-left shadow -->
    <color name="neumorphic_dark_shadow">#C8C8C8</color> <!-- For dark/bottom-right shadow -->
    <color name="neumorphic_light_highlight">#F0F0F0</color> <!-- Slightly brighter than background for highlight -->

    <!-- Text Colors (Light Theme) -->
    <color name="white">#FFFFFF</color>
