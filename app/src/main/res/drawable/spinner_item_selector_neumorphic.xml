<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State when the item is pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <!-- Use neumorphic_dark_shadow for a clear pressed effect -->
            <solid android:color="@color/neumorphic_dark_shadow"/>
        </shape>
    </item>
    <!-- Default state: use the neumorphic background color for individual items -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="@color/neumorphic_background"/>
        </shape>
    </item>
</selector>
