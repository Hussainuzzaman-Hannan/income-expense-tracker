<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Darker inner shadow (top-left) -->
    <item android:top="3dp" android:left="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <solid android:color="@color/neumorphic_dark_shadow"/>
        </shape>
    </item>
    <!-- Lighter inner shadow (bottom-right) -->
    <item android:bottom="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <solid android:color="@color/neumorphic_light_shadow"/>
        </shape>
    </item>
    <!-- Main shape for the input field -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp"/>
            <solid android:color="@color/neumorphic_background"/>
        </shape>
    </item>
</layer-list>
