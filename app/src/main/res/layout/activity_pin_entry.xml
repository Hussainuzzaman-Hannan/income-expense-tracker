<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    tools:context=".PinEntryActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/pin_instruction_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your PIN"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="32dp"
            android:gravity="center"/>

        <EditText
            android:id="@+id/pin_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="PIN"
            android:inputType="numberPassword"
            android:maxLength="4"
            android:textColorHint="@color/neumorphic_dark_shadow"
            android:textColor="@color/black"
            android:background="@drawable/neumorphic_input_background"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/confirm_pin_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirm"
            android:background="@drawable/neumorphic_button_income"
            android:textColor="@color/green_income"
            android:textStyle="bold"
            android:paddingVertical="12dp"
            android:layout_marginBottom="16dp"
            style="?android:attr/buttonBarButtonStyle"/>

        <TextView
            android:id="@+id/set_pin_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No PIN set. Please set a new PIN."
            android:textSize="16sp"
            android:textColor="@color/red_expense"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:gravity="center"/>

        <Button
            android:id="@+id/set_new_pin_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set New PIN"
            android:background="@drawable/neumorphic_button_expense"
            android:textColor="@color/red_expense"
            android:textStyle="bold"
            android:paddingVertical="12dp"
            android:visibility="gone"
            style="?android:attr/buttonBarButtonStyle"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
